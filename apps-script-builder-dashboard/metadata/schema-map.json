{
  "schema_version": "1.0.0",
  "databases": {
    "Apps Script Projects": {
      "purpose": "Canonical Apps Script operational project/build metadata.",
      "fields": [
        "project_id",
        "project_name",
        "agent_owner",
        "workspace_target",
        "output_type",
        "generated_artifact",
        "generated_artifact_file_id",
        "generated_artifact_url",
        "generated_artifact_parent_folder_id",
        "workspace_target_file_id",
        "workspace_target_url",
        "source_document_file_id",
        "source_document_url",
        "handoff_packet_file_id",
        "handoff_packet_url",
        "drive_registry_status",
        "drive_lookup_strategy",
        "last_drive_verified_at",
        "archive_folder_id",
        "archive_status",
        "last_synced_at",
        "build_status",
        "deployment_status",
        "project_risk_level",
        "source_document_relation",
        "unit_id_lookup",
        "lesson_id_lookup",
        "packet_id_lookup",
        "curriculum_readiness_lookup",
        "blocked_until_dashboard_sync_review",
        "blocked_until_drive_ops_review",
        "blocked_reason",
        "created_at",
        "updated_at"
      ],
      "safe_writes": [
        "Apps Script operational metadata",
        "Apps Script-specific build status",
        "Apps Script-generated artifact references",
        "mock/manual Drive registry metadata after artifact creation"
      ],
      "blocked_writes": [
        "curriculum readiness",
        "source authority",
        "source document authority",
        "lesson decisions",
        "packet approval",
        "final generation approval",
        "live Drive folder creation",
        "live Notion or curriculum sync"
      ]
    },
    "Project Logs": {
      "purpose": "Typed log entries for bugs, decisions, performance, deployment, and review notes.",
      "fields": [
        "log_id",
        "project_id",
        "log_type",
        "severity",
        "summary",
        "details",
        "root_cause",
        "fix_applied",
        "prevention_rule",
        "action_name",
        "duration_ms",
        "record_count",
        "cache_status",
        "status",
        "created_at",
        "created_by_agent"
      ]
    },
    "Handoff Records": {
      "purpose": "Governance-safe questions for Dashboard Sync Agent, Drive Operations Manager, or other owner agents.",
      "fields": [
        "handoff_id",
        "project_id",
        "handoff_type",
        "requesting_agent",
        "target_agent",
        "blocked_until_review",
        "question_for_owner",
        "owner_response",
        "approved_contract",
        "handoff_status",
        "created_at",
        "resolved_at"
      ]
    },
    "Change Log": {
      "purpose": "Schema, sync, contract, and implementation changes before and after deployment.",
      "fields": [
        "change_id",
        "project_id",
        "change_type",
        "changed_field",
        "previous_value",
        "new_value",
        "reason",
        "changed_by_agent",
        "requires_owner_review",
        "created_at"
      ]
    },
    "Agent Data Contracts": {
      "purpose": "Field ownership and sync safety contract used by agents and reviewers.",
      "approved_database_label": "Agent/Data Contracts",
      "fields": [
        "contract_id",
        "field_name",
        "classification",
        "owner_database",
        "consuming_database",
        "safe_sync_rule",
        "blocked_until_owner_review",
        "notes",
        "updated_at"
      ]
    }
  },
  "sync_guardrails": {
    "default_sync_mode": "mock",
    "live_notion_curriculum_sync": "blocked",
    "live_drive_automation": "blocked",
    "dry_run_required_before_live_write": true,
    "audit_live_sync_attempts": true,
    "lookup_suffix_blocked": "_lookup",
    "relation_fields_require_owner_review_for_live_write": true
  },
  "writable_field_allowlist": [
    "project_id",
    "project_name",
    "agent_owner",
    "workspace_target",
    "output_type",
    "generated_artifact",
    "generated_artifact_file_id",
    "generated_artifact_url",
    "generated_artifact_parent_folder_id",
    "workspace_target_file_id",
    "workspace_target_url",
    "handoff_packet_file_id",
    "handoff_packet_url",
    "drive_registry_status",
    "drive_lookup_strategy",
    "last_drive_verified_at",
    "archive_folder_id",
    "archive_status",
    "last_synced_at",
    "build_status",
    "deployment_status",
    "project_risk_level",
    "blocked_until_dashboard_sync_review",
    "blocked_until_drive_ops_review",
    "blocked_reason"
  ],
  "denylist": [
    "unit_id",
    "lesson_id",
    "packet_id",
    "readiness_status",
    "source_document",
    "source_authority",
    "curriculum_readiness",
    "lesson_decision",
    "packet_approval",
    "evidence_readiness",
    "reuse_approval",
    "final_generation_approval",
    "curriculum_identity",
    "generation_approval",
    "source_document_relation",
    "source_document_file_id",
    "source_document_url",
    "unit_id_lookup",
    "lesson_id_lookup",
    "packet_id_lookup",
    "curriculum_readiness_lookup"
  ]
}
